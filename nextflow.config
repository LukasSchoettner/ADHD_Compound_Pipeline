params {
    // Default file paths
    interactions_file = "data/ppi_interactions.csv"
    deg_file = "data/degs.csv"
    disease_genes_file = "data/disease_genes.csv"
    target_structure = "data/target.pdb"
    ligand_structure = "data/ligand.pdb"
    input_structure = "data/complex.pdb"
    gene_list_file = "data/genes.csv"
    compound_pairs_file = "data/compound_pairs.csv"

    // GEO dataset parameters
    geo_id = "GSE85871"
    samples = "GSM2286316,GSM2286317,GSM2286238,GSM2286239"
    compound = "Gastrodin"

    // API URL for ADHD-related genes
    api_url = "https://api.example.com/adhd_genes"

    // Simulation parameters
    simulation_time = 100

    // Output directories
    results_dir = "results/"
}

process {
    executor = 'local'
    scratch = true
    errorStrategy = 'retry'
    maxRetries = 2
    memory = '4 GB'
    cpus = 2

    withName: 'analyze_geo' {
        memory = '8 GB'
        cpus = 4
    }

    withName: 'build_ppi_network' {
        memory = '6 GB'
        cpus = 2
    }

    withName: 'molecular_docking' {
        memory = '8 GB'
        cpus = 4
    }

    withName: 'molecular_dynamics' {
        memory = '16 GB'
        cpus = 8
    }
}

timeline {
    enabled = true
    file = 'timeline.html'
}

trace {
    enabled = true
    file = 'trace.txt'
    overwrite = true
}

report {
    enabled = true
    file = 'report.html'
}

log {
    file = "nextflow.log"
}
