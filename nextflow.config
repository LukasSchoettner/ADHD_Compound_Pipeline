timeline {
    enabled = true
    file = 'timeline.html'
    overwrite = true
}

trace {
    enabled = true
    file = 'trace.txt'
    overwrite = true
}

report {
    enabled = true
    file = 'report.html'
    overwrite = true
}

log {
    file = "nextflow.log"
    overwrite = true
}
